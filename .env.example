BOT_TOKEN=123456:replace-with-botfather-token
ALLOWED_CHAT_ID=000000000
POLL_TIMEOUT=50

# /usage quota % requires `cswap` (Multi-Account Switcher for Claude Code)
# installed on PATH — no config needed here.

# Optional — group/topics mode. Set to a private supergroup id (negative) to
# run each project in its own forum topic instead of the DM. Leave blank = DM.
# Requires: bot privacy OFF (BotFather /setprivacy), bot admin + Manage Topics,
# group Topics enabled. ALLOWED_CHAT_ID stays your user id (owner auth).
GROUP_CHAT_ID=
